# GEMINI_API_KEY: Required for Gemini Nano Banana (gemini-2.5-flash-image)
GEMINI_API_KEY=

# ADSENSE_PUB_ID: Your Google AdSense Publisher ID (ca-pub-...)
VITE_ADSENSE_PUB_ID="ca-pub-3940256099942544"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
